# Google Workspace — OAuth handled via credentials.json + token.json
# No env vars needed for Google (auth is file-based)

# GitLab (optional)
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4

# Slack (optional — create app at api.slack.com/apps)
SLACK_USER_TOKEN=

# Cloudflare (optional)
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=

# Resend — email sending (optional — get key at resend.com)
RESEND_API_KEY=

# Google Drive sync path (default: /g/My Drive/Backup/bot-secrets)
# SYNC_DRIVE_PATH=/g/My Drive/Backup/bot-secrets
