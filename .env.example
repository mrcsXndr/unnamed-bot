# Copy this file to .env and fill in only what you use — or better, run the
# setup wizard (scripts/setup.sh or scripts/setup.ps1), which writes .env for
# you. .env is gitignored — never commit real values.

# =============================================================================
# REQUIRED (the setup wizard prompts for these three)
# =============================================================================

# What your bot is called (shown in the launcher; used in docs/messages).
BOT_NAME=YOUR_BOT_NAME_HERE

# --- Telegram --------------------------------------------------------------
# Create a bot with @BotFather (https://t.me/BotFather), copy the token.
# To find your chat id: message your new bot once, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates and read "chat":{"id":...}.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# =============================================================================
# FEATURE FLAGS (all OPT-IN, all default off; the setup wizard asks about each)
# Hooks and scripts read these — flip to 1/0 any time to enable/disable.
# =============================================================================

# Google Workspace tools (tools/google/*) — needs credentials.json OAuth setup.
FEATURE_GOOGLE=0

# Commit + push memory/ to your git remote on session stop; pull on start.
# (tools/infra/memory-sync-hook.cjs — touches your GitHub/GitLab remote.)
FEATURE_MEMORY_SYNC=0

# Auto-commit ALL uncommitted repo changes locally on session stop.
FEATURE_AUTO_COMMIT=0

# Background LLM debrief on session stop (spawns `claude --print`; costs tokens).
FEATURE_SESSION_DEBRIEF=0

# Mirror secrets (.env, credentials.json, token.json) to a cloud/USB folder.
# Requires SYNC_DRIVE_PATH below.
FEATURE_SECRETS_BACKUP=0

# Hourly resource janitor inside the supervisor tick (Windows; needs the
# supervisor scheduled task).
FEATURE_MONITORS=0

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# --- Task board (optional) ---------------------------------------------------
# A Google Sheet with a `Tasks` tab; enables the /tasks Telegram command.
# TASK_BOARD_SHEET_ID=your-google-sheet-id

# --- Groq (optional — voice-note transcription via Whisper) ------------------
# Get a free key at https://console.groq.com
# GROQ_API_KEY=...

# --- Slack (optional) ---------------------------------------------------------
# Create an app at https://api.slack.com/apps, add User Token Scopes, install,
# and copy the token that starts with xoxp-
# SLACK_USER_TOKEN=xoxp-...

# --- GitLab (optional) --------------------------------------------------------
# GITLAB_PERSONAL_ACCESS_TOKEN=...
# GITLAB_API_URL=https://gitlab.com/api/v4

# --- Cloudflare (optional) ----------------------------------------------------
# CLOUDFLARE_API_KEY=...
# CLOUDFLARE_EMAIL=you@example.com

# --- Resend (optional — send email as the bot) --------------------------------
# RESEND_API_KEY=...

# --- Multi-machine secrets backup (pair with FEATURE_SECRETS_BACKUP=1) --------
# Point at any mounted cloud/USB folder; tools/infra/sync_settings.sh mirrors
# secrets here.
# SYNC_DRIVE_PATH=/path/to/your/cloud/backup

# =============================================================================
# TUNABLES (defaults are sensible; uncomment to override)
# =============================================================================

# Windows Terminal profile the supervisor/restart flow should launch (a
# profile whose command line runs scripts\launch.ps1 -Continue).
# BOT_WT_PROFILE=MyBot

# Skip the status footer on outbound Telegram messages (default: appended).
# BOT_TG_STATUS=0

# Chars of journal tail injected at session start (default 20000).
# BOT_JOURNAL_HEAD_BYTES=20000

# Large-paste guard threshold in chars (default 50000).
# BOT_SIZE_THRESHOLD=50000

# Model + timeout for journal->timeline distillation (tools/v2/timeline.py).
# BOT_DISTILL_MODEL=claude-opus-4-8
# BOT_DISTILL_TIMEOUT=180

# Heartbeat re-alert cooldown for due commitments, hours (default 6).
# BOT_HEARTBEAT_COOLDOWN_H=6

# Min hours between background session-debrief runs (Stop hook; default 6).
# BOT_DEBRIEF_GATE_HOURS=6

# Min seconds between secrets-backup pushes to the sync folder (default 21600 = 6h).
# BOT_PUSH_MIN_INTERVAL=21600

# Memory-sync committer identity (defaults: bot-memory / bot-memory@localhost).
# MEMORY_GIT_NAME=bot-memory
# MEMORY_GIT_EMAIL=bot-memory@localhost
