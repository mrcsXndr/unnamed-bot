# Copy this file to .env and fill in only the services you use. Everything is
# optional except Google (which authenticates via credentials.json, not here).
# .env is gitignored — never commit real values.

# --- Google Workspace -------------------------------------------------------
# OAuth is file-based via credentials.json + token.json (see tools/google_auth.py).
# No env vars needed here.

# --- Telegram (optional) ----------------------------------------------------
# Create a bot with @BotFather, then message it and visit
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- Groq (optional — voice-note transcription via Whisper) -----------------
# Get a free key at https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# --- Slack (optional) -------------------------------------------------------
# Create an app at https://api.slack.com/apps, add User Token Scopes, install,
# and copy the token that starts with xoxp-
SLACK_USER_TOKEN=xoxp-YOUR_SLACK_USER_TOKEN_HERE

# --- GitLab (optional) ------------------------------------------------------
GITLAB_PERSONAL_ACCESS_TOKEN=YOUR_GITLAB_PAT_HERE
GITLAB_API_URL=https://gitlab.com/api/v4

# --- Cloudflare (optional) --------------------------------------------------
CLOUDFLARE_API_KEY=YOUR_CLOUDFLARE_GLOBAL_API_KEY_HERE
CLOUDFLARE_EMAIL=you@example.com

# --- Resend (optional — send email as the bot) ------------------------------
# Get a key at https://resend.com
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE

# --- Browser automation (optional overrides for tools/browser.py) -----------
# CHROME_CDP_URL=http://localhost:9222
# CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROME_PROFILE=Default

# --- Context warning hook (optional) ----------------------------------------
# Set if you run a 1M-context model so context % warnings are accurate.
# CONTEXT_LIMIT_TOKENS=1000000

# --- Multi-machine sync (optional) ------------------------------------------
# Point at any mounted cloud/USB folder; sync_settings.sh mirrors secrets here.
# BOT_SECRETS_DIR takes precedence over SYNC_DRIVE_PATH.
# BOT_SECRETS_DIR=$USERPROFILE/AssistantBot-secrets
# SYNC_DRIVE_PATH=/path/to/your/cloud/backup

# --- v2 resilience / journal / orchestration (all optional, sane defaults) --
# Explicit python interpreter for the PowerShell supervisor/watchdog scripts
# (otherwise discovered from PATH):
# BOT_PYTHON=C:\path\to\python.exe
# Override the derived Claude Code project slug used by the cost meter:
# BOT_PROJECT_SLUG=C--Users-you-Code-my-bot
# Journal load cap at session start (chars), large-paste guard threshold (chars),
# status-footer context denominator (tokens), update-restart idle gate (minutes):
# BOT_V2_JOURNAL_HEAD_BYTES=20000
# BOT_V2_SIZE_THRESHOLD=50000
# BOT_V2_MAX_CONTEXT=500000
# BOT_IDLE_MIN=5
# Timeline distill model + timeouts, safe_write lock timeout, weekly-distill gate:
# BOT_V2_DISTILL_MODEL=claude-opus-4-8
# BOT_V2_DISTILL_TIMEOUT=180
# BOT_V2_LOCK_TIMEOUT=10
# BOT_V2_WEEKLY_GATE_H=6
