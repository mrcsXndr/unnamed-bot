.env
.dev.vars
credentials.json
token.json
.credentials/
*-svctoken*
node_modules/
logs/
*.log
.DS_Store

# Generated runtime state (not meant for git)
.context_state.json
.context_warn_tg_lock
MEMORY_SYNC_CONFLICT.md
screenshots/*
!screenshots/.gitkeep
tools/__pycache__/
__pycache__/
*.pyc

# Done-sound binaries (optional, user-supplied)
.claude/hooks/sounds/done.*

# v2 runtime state + markers (machine-specific, regenerated on launch)
.claude/.current_session_id
.claude/.bot_v2_state.json
.claude/.tg_owner.lock
.claude/.bot_fresh_restart
.claude/.bot_v2_update_stamp
.claude/stash/
scripts/bot-supervisor-hidden.vbs

# v2 ephemeral per-session working memory (only keep the index/structure)
memory/sessions/*/
!memory/sessions/.gitkeep
# v2 per-session snapshots written by session_summarize.py (rebuildable)
memory/sessions/*.md
# v2 ephemeral per-project git-state snapshots from state_track.py
memory/projects/*/
!memory/projects/.gitkeep
# v2 rebuildable FTS5 recall index (regenerate with `recall.py index`)
memory/index/*
!memory/index/.gitkeep
# v2 promoted long-term salvage + weekly timelines + metrics (machine-local)
memory/longterm/*
!memory/longterm/.gitkeep
memory/timelines/*
!memory/timelines/.gitkeep
memory/metrics/*
!memory/metrics/.gitkeep
# safe_write lock/backup sidecars
*.lock
*.bak.*

# NOTE: memory/ is otherwise tracked so notes sync across machines.
# Keep secrets OUT of memory/.
