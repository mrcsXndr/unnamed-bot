.env
.dev.vars
credentials.json
token.json
.credentials/
*-svctoken*
node_modules/
logs/
*.log
.DS_Store

# Generated runtime state (not meant for git)
MEMORY_SYNC_CONFLICT.md
screenshots/*
!screenshots/.gitkeep
__pycache__/
*.pyc

# v2 runtime state (session-local; regenerated)
.claude/.current_session_id
.claude/.bot_state.json
.claude/.bot_fresh_restart
.claude/.bot_update_stamp
.claude/.tg_owner.lock
.claude/.monitor_ticks.json
.claude/stash/
memory/index/
memory/commitments.json
memory/*.lock
memory/**/*.lock
tools/infra/.resource_monitor_state.json
scripts/supervisor-hidden.vbs

# Done-sound binaries (optional, user-supplied)
.claude/hooks/sounds/done.*

# Generated per-session working memory + metrics. The template ships DATA-FREE:
# the scaffold (MEMORY.md, personality.md, READMEs, .gitkeep dirs) is tracked so
# a fresh clone has structure, but YOUR sessions/metrics/logs stay local. If you
# want cross-machine memory sync (like the reference bots), remove these lines.
memory/sessions/*/
memory/timelines/
memory/metrics/*.csv
memory/metrics/*.log
!memory/sessions/README.md
!memory/**/.gitkeep
