{
  "env": {
    "PYTHONIOENCODING": "utf-8",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "statusLine": {
    "type": "command",
    "command": "node tools/statusline.js"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-context.sh"
          },
          {
            "type": "command",
            "command": "node tools/memory-sync-hook.cjs",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/context_warn_hook.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/session_summarize.py --quiet",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/play-sound.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-debrief.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python tools/session_summarize.py --quiet",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node tools/memory-sync-hook.cjs",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
