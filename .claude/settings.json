{
  "env": {
    "PYTHONIOENCODING": "utf-8"
  },
  "permissions": {
    "deny": [
      "AskUserQuestion",
      "ExitPlanMode"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node tools/infra/statusline.js"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dialogs.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-v2.sh"
          },
          {
            "type": "command",
            "command": "node tools/infra/memory-sync-hook.cjs",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/user-prompt-submit.sh",
            "timeout": 15,
            "statusMessage": "Routing prompt (v2)..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-subagent.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/v2/precompact_extract.py --stdin || true",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python tools/v2/precompact_timeline.py --stdin || true",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node tools/infra/memory-sync-hook.cjs",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/play-sound.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-debrief.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit.sh"
          },
          {
            "type": "command",
            "command": "python tools/v2/cost_meter.py --stdin || true",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
